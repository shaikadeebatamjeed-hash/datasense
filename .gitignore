# Created by venv; see https://docs.python.org/3/library/venv.html
*# Virtual environment - never commit, it's reproducible via requirements.txt
.venv/

# Python cache files - auto-generated by Python when it runs
__pycache__/
*.pyc

# Data folder - datasets are often large and shouldn't bloat the repo
data/

# Jupyter notebook checkpoints - auto-generated junk
.ipynb_checkpoints/

# OS-specific junk files
.DS_Store
Thumbs.db

# VS Code settings (personal editor preferences, not project code)
.vscode/

